# ─────────────────────────────────────────────────────────────────────────────
# QR Studio — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string (required).
# Get this from MongoDB Atlas → Connect → Drivers → Node.js.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI="mongodb+srv://Walid:Wal123@cluster0.f3h3jin.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0"
DB_NAME="qr-code-generator"

# ── App URL ───────────────────────────────────────────────────────────────────
# Public base URL — used to build scan URLs shown to the user.
# In production set this to your deployed domain, e.g. https://qrstudio.example.com
# No trailing slash.
NEXT_PUBLIC_APP_URL=https://myqrcode-opal.vercel.app

# ── Auth (reserved for future use) ───────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Required if you add NextAuth.js authentication later.
NEXTAUTH_SECRET=
